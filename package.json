{
  "name": "pet-workbuddy",
  "version": "0.1.2",
  "private": true,
  "description": "Open-source AI desktop pet with configurable model providers and custom pet packs.",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter @workbuddy/desktop dev",
    "build": "pnpm --filter @workbuddy/desktop build",
    "desktop": "pnpm --filter @workbuddy/desktop tauri:dev",
    "desktop:pack": "pnpm --filter @workbuddy/desktop tauri:build",
    "preview": "pnpm --filter @workbuddy/desktop preview",
    "tauri:dev": "pnpm --filter @workbuddy/desktop tauri:dev",
    "tauri:build": "pnpm --filter @workbuddy/desktop tauri:build",
    "lint": "pnpm --filter @workbuddy/desktop lint",
    "typecheck": "pnpm --filter @workbuddy/desktop typecheck"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@11.7.0"
}
