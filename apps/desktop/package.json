{
  "name": "@workbuddy/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source AI desktop pet with configurable model providers and custom pet packs.",
  "author": "hillmanpick",
  "license": "MIT",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "electron:start": "pnpm build && electron electron/main.cjs",
    "electron:pack": "pnpm build && electron-builder --win portable --x64",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "tsc -b --pretty false",
    "typecheck": "tsc -b --pretty false",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^1.6.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.166.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^1.6.0",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.166.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  },
  "build": {
    "appId": "com.hillmanpick.workbuddy",
    "productName": "WorkBuddy",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "WorkBuddy-${version}-${arch}.${ext}"
    }
  }
}
