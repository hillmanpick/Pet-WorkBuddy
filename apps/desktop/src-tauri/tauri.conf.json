{
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devPath": "http://127.0.0.1:5176",
    "distDir": "../dist"
  },
  "package": {
    "productName": "WorkBuddy",
    "version": "0.1.6"
  },
  "tauri": {
    "allowlist": {
      "all": true,
      "http": {
        "all": true,
        "scope": [
          "https://*",
          "http://*"
        ]
      },
      "protocol": {
        "asset": true,
        "assetScope": [
          "$APPDATA/pet-packs/**"
        ]
      }
    },
    "bundle": {
      "active": true,
      "category": "Productivity",
      "copyright": "Copyright (c) 2026 hillmanpick",
      "identifier": "com.hillmanpick.workbuddy",
      "icon": [
        "icons/icon.ico"
      ],
      "windows": {
        "nsis": {
          "installerIcon": "icons/icon.ico"
        }
      },
      "targets": "all"
    },
    "security": {
      "csp": null
    },
    "systemTray": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false
    },
    "windows": [
      {
        "title": "WorkBuddy",
        "width": 340,
        "height": 548,
        "minWidth": 280,
        "minHeight": 500,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "fileDropEnabled": false,
        "resizable": true,
        "skipTaskbar": true,
        "center": true
      }
    ]
  }
}
