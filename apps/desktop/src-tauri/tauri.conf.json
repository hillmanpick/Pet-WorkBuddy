{
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devPath": "http://127.0.0.1:5175",
    "distDir": "../dist"
  },
  "package": {
    "productName": "WorkBuddy",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": true
    },
    "bundle": {
      "active": true,
      "category": "Productivity",
      "copyright": "Copyright (c) 2026 hillmanpick",
      "identifier": "com.hillmanpick.workbuddy",
      "icon": [
        "icons/icon.ico"
      ],
      "targets": "all"
    },
    "security": {
      "csp": null
    },
    "systemTray": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false
    },
    "windows": [
      {
        "title": "WorkBuddy",
        "width": 340,
        "height": 360,
        "minWidth": 280,
        "minHeight": 260,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": true,
        "skipTaskbar": false,
        "center": true
      }
    ]
  }
}
